<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<!-- BLE physical board (S-09). Required or the app crashes on first CBCentralManager use; the
	     system Bluetooth prompt shows this string. Foreground-first — no UIBackgroundModes. -->
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Smart Chessboard connects over Bluetooth to play on your physical reed-switch board.</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>org.rurbaniak.smartchessboard.auth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.smartchessboard</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
